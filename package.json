{
  "name": "decision-engine-core",
  "version": "0.1.0",
  "description": "Rule-driven decision core for evaluating sensor input and returning state and action.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "example": "node examples/temperature.js",
    "example:node-temp-sim": "node examples/node-temp-sim/index.js",
    "example:node-temp-sim:sample": "node examples/node-temp-sim/index.js --config examples/node-temp-sim/exported-config.sample.json --input examples/node-temp-sim/input-sequence.sample.json",
    "check:evaluate": "node scripts/check-evaluate.js",
    "check:config": "node scripts/check-config.js",
    "evaluate": "node scripts/evaluate-cli.js",
    "cpp:test-vectors": "mkdir -p build && g++ -std=c++17 runtimes/cpp/DecisionEngine.cpp runtimes/cpp/run_test_vectors.cpp -o build/cpp-test-vectors && ./build/cpp-test-vectors && g++ -std=c++17 runtimes/cpp/DecisionEngine.cpp runtimes/cpp/run_generated_config_test.cpp -o build/cpp-generated-config-test && ./build/cpp-generated-config-test",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^9.26.0",
    "prettier": "^3.5.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tstaisyu/decision-engine-core.git"
  },
  "keywords": [
    "decision-engine",
    "rules",
    "temperature-control",
    "m5stack",
    "nodejs"
  ],
  "license": "Apache-2.0",
  "packageManager": "yarn@1.22.22+sha256.c17d3797fb9a9115bf375e31bfd30058cac6bc9c3b8807a3d8cb2094794b51ca"
}
